# 模型文件
*.h5 filter= diff= merge= -text
*.hdf5 filter= diff= merge= -text
*.ckpt filter= diff= merge= -text
*.pt filter= diff= merge= -text
*.pth filter= diff= merge= -text
*.onnx filter= diff= merge= -text
*.tflite filter= diff= merge= -text
*.pb filter= diff= merge= -text

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar filter= diff= merge= -text
*.gz filter= diff= merge= -text

# Python
__pycache__/ export-ignore
*.pyc export-ignore
*.pyo export-ignore

# IDE
.vscode/ export-ignore
.idea/ export-ignore

# 日志和临时文件
logs/ export-ignore
*.log export-ignore

# Poetry
poetry.lock export-ignore
